# ──────────────────────────────────────────────
# JSR-Payment-Agent  —  Environment Variables
# ──────────────────────────────────────────────

# Google AI / Gemini
GOOGLE_API_KEY=your-google-api-key-here

# Model Configuration
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS — comma-separated origins allowed by the frontend
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
